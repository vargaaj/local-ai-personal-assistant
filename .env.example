# Qdrant document-vector store
# Prefer https:// when Qdrant TLS is enabled. A tailnet-only http:// URL is
# encrypted by Tailscale, but qdrant-client cannot detect that and will warn
# when an API key is configured.
QDRANT_URL=<qdrant-tailnet>
QDRANT_API_KEY=
QDRANT_COLLECTION=local_documents

# Local document library and assistant state
# Use a Windows path when launching from PowerShell/Conda on Windows.
RAG_DOCS_ROOT=<local-dir>
# Relative manifest and state paths resolve from the Uvicorn launch directory.
RAG_MANIFEST_PATH=.rag_manifest.json
RAG_STATE_DB_PATH=.rag_state.sqlite3
RAG_USER_NAME=Andrew Varga

# Local Ollama model
# Use the root URL. Legacy values ending in /v1 are normalized automatically.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nemotron-3-nano:4b
# Increase this for longer answers.
OLLAMA_MAX_TOKENS=192
# Optional: enables the Ollama cloud web-search API.
OLLAMA_API_KEY=

# MLflow tracing and prompt registry
MLFLOW_TRACKING_URI=<mlflow-tailnet>
MLFLOW_EXPERIMENT=local-ai-assistant
MLFLOW_PROMPT_NAME=local-ai-assistant-system-prompt
MLFLOW_PROMPT_ALIAS=production

# FastEmbed document embeddings
FASTEMBED_MODEL=mixedbread-ai/mxbai-embed-large-v1
FASTEMBED_VECTOR_SIZE=1024
# For CPU embeddings, set FASTEMBED_CUDA=false and leave providers and device IDs empty.
FASTEMBED_CUDA=true
FASTEMBED_PROVIDERS=CUDAExecutionProvider
FASTEMBED_DEVICE_IDS=0
FASTEMBED_BATCH_SIZE=256
CHUNK_SIZE=1200
# Keep overlap smaller than chunk size.
CHUNK_OVERLAP=200
# Cosine-similarity cutoff for document retrieval. Supported range: -1 to 1.
RETRIEVAL_SCORE_THRESHOLD=0.35

# LangGraph assistant behavior
AGENT_MAX_CONCURRENT_RUNS=1
MEMORY_FACT_LIMIT=100
# Ollama web search supports 1 to 10 results.
WEB_SEARCH_MAX_RESULTS=5
RESEARCH_QUERY_COUNT=3
